# OpenAI (server-only — /api/* AI routes require a signed-in Supabase user)
OPENAI_API_KEY=

# Supabase (client + server)
# service_role must be from the SAME project as SUPABASE_URL / NEXT_PUBLIC_SUPABASE_URL
# Apply migrations once after linking: supabase login && supabase db push
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=https://landed-ai.com
NEXT_PUBLIC_SITE_URL=https://landed-ai.com

# Stripe (server-only — /api/stripe/*)
# Products (live mode for launch):
#   Set these from Stripe Dashboard → Product catalog → Pricing.
# Webhooks: Dashboard → Developers → Webhooks → Add endpoint
#   URL: https://landed-ai.com/api/webhooks/stripe
#   (rewrites to /api/stripe/webhook)
#   Events: checkout.session.completed, invoice.paid, invoice.payment_failed,
#           customer.subscription.updated, customer.subscription.deleted
#   Local dev: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Pro monthly — must match src/lib/regional-pricing.ts (£/$/€ 24.99, A$39.99, C$34.99)
STRIPE_PRODUCT_PRO_MONTHLY=
STRIPE_PRICE_PRO=
# Pro annual — ~30% off (£/$/€ 209.92/yr)
STRIPE_PRODUCT_PRO_ANNUAL=
STRIPE_PRICE_PRO_ANNUAL=
# Regional Pro prices (optional — falls back to USD when unset)
STRIPE_PRICE_PRO_GBP=
STRIPE_PRICE_PRO_GBP_ANNUAL=
STRIPE_PRICE_PRO_EUR=
STRIPE_PRICE_PRO_EUR_ANNUAL=
STRIPE_PRICE_PRO_AUD=
STRIPE_PRICE_PRO_AUD_ANNUAL=
STRIPE_PRICE_PRO_CAD=
STRIPE_PRICE_PRO_CAD_ANNUAL=
# Lifetime one-time — £/$/€ 797 (was 1598); A$1275 / C$1116
STRIPE_PRODUCT_LIFETIME=
STRIPE_PRICE_LIFETIME=
STRIPE_PRICE_LIFETIME_GBP=
STRIPE_PRICE_LIFETIME_EUR=
STRIPE_PRICE_LIFETIME_AUD=
STRIPE_PRICE_LIFETIME_CAD=
# Optional — only needed if you add client-side Stripe.js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Vercel Blob upload for Mac DMG (local release only — run: npm run upload-download)
BLOB_READ_WRITE_TOKEN=
# NEXT_PUBLIC_MAC_DOWNLOAD_URL=https://koen8vbjbnttgldm.public.blob.vercel-storage.com/downloads/Landed.dmg
# NEXT_PUBLIC_WINDOWS_DOWNLOAD_URL=https://koen8vbjbnttgldm.public.blob.vercel-storage.com/downloads/Landed-Setup.exe
# Soft-launch: leave unset/false until Landed-Setup.exe is published
# NEXT_PUBLIC_WINDOWS_AVAILABLE=true
# GitHub repo that owns Desktop Release tags (default: archuenmsnmmm/landed)
# GITHUB_RELEASE_REPO=archuenmsnmmm/landed

# Required to access /api/stripe/status (any environment)
ADMIN_STATUS_SECRET=

# Vite / desktop app (copy from above where noted)
# VITE_OPENAI_API_KEY is dev-only; production desktop uses authenticated /api/* routes
VITE_OPENAI_API_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_USE_MOCK_AUDIO=false
VITE_LEGAL_BASE_URL=https://landed-ai.com
# Point at your Next.js server (http://localhost:3000 locally; landed-ai.com in packaged builds)
VITE_API_BASE_URL=https://landed-ai.com
VITE_GOOGLE_CLIENT_ID=821453006387-snrakrrq6n17m5pde2nfshmnf8nanmc6.apps.googleusercontent.com

# Google OAuth (Supabase — required for desktop "Continue with Google"):
# 1. Google Cloud → OAuth client → Authorized redirect URI:
#    https://epeitwkgbfabevxyznrh.supabase.co/auth/v1/callback
# 2. From repo root (after `supabase login`):
#    GOOGLE_CLIENT_SECRET=GOCSPX-... ./scripts/setup-google-auth.sh
